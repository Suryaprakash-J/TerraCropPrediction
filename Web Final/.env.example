# ═══════════════════════════════════════════════════════════════════════════
# TerraAI – Environment Variables Template
# Copy this file to .env and fill in your real values.
# This file IS safe to commit — it contains no real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=your-strong-random-secret-key-here
FLASK_DEBUG=true
PORT=5000

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── OpenWeatherMap API ────────────────────────────────────────────────────────
# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key-here

# ── Gmail SMTP (for OTP emails) ───────────────────────────────────────────────
# Use a Gmail App Password — NOT your account password.
# Enable 2FA then generate at: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-gmail-address@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
