# ═══════════════════════════════════════════════════════════════════════════
# TerraAI – Environment Variables Template
# Copy this file to .env and fill in your real values.
# This file IS safe to commit — it contains no real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=your-strong-random-secret-key-here
FLASK_DEBUG=true
PORT=5000

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI__KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── OpenWeatherMap API ────────────────────────────────────────────────────────
# Get your free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key-here

# ── Resend API (replaces SMTP — works on Railway/Render) ─────────────────────
# Get your free API key at: https://resend.com  (100 emails/day free)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=TerraAI <onboarding@resend.dev>
